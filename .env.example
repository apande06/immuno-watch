# ImmunoWatch environment configuration (copy to .env and adjust as needed)

# --- API ---
IMMUNOWATCH_API_HOST=0.0.0.0
IMMUNOWATCH_API_PORT=8000

# --- Database ---
# Async SQLAlchemy URL. Default is a local SQLite file via aiosqlite.
IMMUNOWATCH_DATABASE_URL=sqlite+aiosqlite:///./immunowatch.db

# --- Dashboard (Vite) ---
# Base URL the React dashboard uses to reach the API.
VITE_API_BASE_URL=http://localhost:8000

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
IMMUNOWATCH_LOG_LEVEL=INFO

# --- ML ---
# Master seed for reproducible data generation and training.
IMMUNOWATCH_RANDOM_SEED=42
